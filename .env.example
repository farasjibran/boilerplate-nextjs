# Environment
NODE_ENV=development

# App
NEXT_PUBLIC_APP_NAME="Boilerplate Next.js"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# Auth (Auth.js v5)
AUTH_SECRET="your-secret-here"
AUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/boilerplate?schema=public"

# Sentry (observability)
SENTRY_DSN=""
